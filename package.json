{
  "name": "vault",
  "version": "2.8.5",
  "description": "Your private media sanctuary with AI companion",
  "author": "Vault Team",
  "private": true,
  "type": "module",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:raw": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "build:dir": "electron-vite build && electron-builder --dir",
    "build:local": "electron-vite build && electron-builder --config.npmRebuild=false",
    "watch": "node scripts/watch-build.mjs",
    "preview": "electron-vite preview",
    "postinstall": "patch-package",
    "install:aesthetic": "node scripts/install-aesthetic-predictor.mjs"
  },
  "dependencies": {
    "@base-ui-components/react": "^1.0.0-rc.0",
