    "@fontsource/playfair-display": "^5.2.8",
    "@fontsource/roboto-slab": "^5.2.8",
    "@fontsource/sacramento": "^5.2.8",
    "@fontsource/vt323": "^5.2.7",
    "@fontsource/wallpoet": "^5.2.7",
    "@helia/unixfs": "^7.2.1",
    "@mediapipe/tasks-vision": "^0.10.35",
    "@number0/iroh": "^0.35.0",
    "@phosphor-icons/react": "^2.1.10",
    "@ricky0123/vad-web": "^0.0.30",
    "@sentry/electron": "^7.13.0",
    "@simplewebauthn/browser": "^13.3.0",
    "@simplewebauthn/server": "^13.3.0",
    "@tanstack/react-virtual": "^3.13.24",
    "@types/mailparser": "^3.4.6",
    "@types/react-window": "^1.8.8",
    "animejs": "^4.3.5",
    "better-sqlite3": "^11.10.0",
    "canvas-confetti": "^1.9.4",
    "chokidar": "^3.6.0",
    "chromecast-api": "^0.4.2",
    "clsx": "^2.1.1",
    "cron-parser": "^5.5.0",
    "dlnacasts2": "^0.2.0",
    "echarts": "^6.0.0",
    "echarts-for-react": "^3.0.6",
    "electron-log": "^5.4.3",
    "electron-store": "^10.0.0",
    "exiftool-vendored": "^35.20.0",
    "fast-glob": "^3.3.2",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "fuse.js": "^7.3.0",
    "gsap": "^3.14.2",
    "helia": "^6.1.4",
    "hls.js": "^1.6.16",
    "hyperswarm": "^4.17.0",
    "imapflow": "^1.3.3",
    "libass-wasm": "^4.1.0",
    "lucide-react": "^0.516.0",
    "mailparser": "^3.9.8",
    "masonic": "^4.1.0",
    "motion": "^12.38.0",
    "mqtt": "^5.15.1",
    "multiformats": "^14.0.0",
    "nanoid": "^5.0.9",
    "node-vibrant": "^4.0.4",
    "nostr-tools": "^2.23.3",
    "onnxruntime-node": "^1.24.1",
    "photoswipe": "^5.4.4",
    "qrcode": "^1.5.4",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hotkeys-hook": "^5.3.2",
    "react-window": "^2.2.5",
    "recharts": "^3.8.1",
    "rss-parser": "^3.13.0",
    "serialport": "^13.0.0",
    "shamirs-secret-sharing": "^2.0.1",
    "sharp": "^0.34.5",
    "simple-peer": "^9.11.1",
    "simplex-noise": "^4.0.3",
    "tesseract.js": "^7.0.0",
    "wavesurfer.js": "^7.12.6"
  },
  "devDependencies": {
    "@types/animejs": "^3.1.13",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^24.10.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/wavesurfer.js": "^6.0.12",
    "@types/web-bluetooth": "^0.0.21",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.21",
    "babel-plugin-react-compiler": "^1.0.0",
    "electron": "32.3.3",
    "electron-builder": "^24.13.3",
    "electron-vite": "^5.0.0",
    "knip": "^6.12.1",
    "patch-package": "^8.0.1",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.3",
    "vite": "^5.4.21",
    "zod": "^4.1.11"
  },
  "build": {
    "appId": "com.vault.app",
    "productName": "Vault",
    "files": [
      "out/**/*",
      "package.json",
      "node_modules/better-sqlite3/**/*",
      "node_modules/bindings/**/*",
      "node_modules/file-uri-to-path/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/ffmpeg-static/ffmpeg.exe",
        "to": "ffmpeg.exe"
      },
      {
        "from": "node_modules/ffprobe-static/bin/win32/x64/ffprobe.exe",
        "to": "ffprobe.exe"
      },
      {
        "from": "resources/bin/yt-dlp.exe",
        "to": "bin/yt-dlp.exe"
      }
    ],
    "directories": {
      "output": "release"
    },
    "asar": true,
    "asarUnpack": [
      "**/*.node",
      "**/better-sqlite3/**",
      "**/ffmpeg-static/**",
      "**/ffprobe-static/**"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "V.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "publish": {
      "provider": "github",
      "owner": "Nwund",
      "repo": "vault-project"
    }
  },
  "optionalDependencies": {
    "@emnapi/core": "1.10.0",
    "@emnapi/runtime": "1.10.0"
  }
}
